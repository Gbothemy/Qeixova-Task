DATABASE_URL=
JWT_SECRET=
ADMIN_SECRET=
ADMIN_EMAIL=admin@qeixova.com
# Optional if ADMIN_SECRET is set. In production, ADMIN_SECRET is used as the login password when ADMIN_PASSWORD is empty.
