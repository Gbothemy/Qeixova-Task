# Public app URL used in emails and links
NEXT_PUBLIC_APP_URL=

# Optional email delivery
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Future payment integration
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
